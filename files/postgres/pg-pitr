#!/bin/bash
set -uo pipefail
#==============================================================#
# File      :   pg-pitr
# Desc      :   Point-in-time recovery with pgbackrest
# Ctime     :   2022-12-31
# Mtime     :   2026-06-10
# Path      :   /pg/bin/pg-pitr
# Deps      :   pgbackrest, /etc/pgbackrest/pgbackrest.conf
# License   :   Apache-2.0 @ https://pigsty.io/docs/about/license/
# Copyright :   2018-2026  Ruohang Feng / Vonng (rh@vonng.com)
#==============================================================#
# This script restores a PostgreSQL data directory to a specific
# point in time using pgbackrest. It's a single-purpose tool that:
#   - Uses the backup repository configured on current node
#   - Restores to specified data directory
#   - Supports various recovery targets (time, lsn, xid, name, etc.)
#
# Usage: https://pgbackrest.org/command.html#command-restore
#==============================================================#
PROG_NAME="$(basename $0)"
PROG_DIR="$(cd $(dirname $0) && pwd)"


#--------------------------------------------------------------#
# Usage
#--------------------------------------------------------------#
usage() {
    cat <<-'EOF'
NAME
    pg-pitr   -- Point-in-time recovery with pgbackrest

SYNOPSIS
    pg-pitr [options] [--time=<time>|--lsn=<lsn>|--xid=<xid>|--name=<name>] [--set=<backup>] [-- <pgbackrest-options>]

RECOVERY TARGET (choose one):
    -d, --default              Recover to end of WAL archive stream (latest status)
    -i, --immediate            Recover only until database becomes consistent
    -t, --time  <timestamp>    Recover to specific time (e.g., "2025-01-01 12:00:00+08")
    -n, --name  <restore_point> Recover to named restore point
    -l, --lsn   <lsn>          Recover to specific LSN (e.g., "0/7C82CB8")
    -x, --xid   <xid>          Recover to specific transaction ID

OPTIONS:
    -D, --data   <path>        Data directory to restore (default: /pg/data)
    -s, --stanza <name>        pgbackrest stanza name (auto-detect from config)
    -S, --set    <label>       Restore from specific backup set (can combine with target)
    -b, --backup <label>       Alias for --set (backward compatible)
    -X, --exclusive            Stop RIGHT BEFORE target (exclusive), not at it
    -P, --promote              Promote after reaching target (default: pause)
    -T, --timeline <timeline>  Recover along a specific timeline: latest, current, or N
    -v, --verbose              Show pgBackRest info-level console output
    -c, --check                Dry-run mode: print command without executing
    -y, --yes                  Skip confirmation and countdown
    -h, --help                 Show this help message

EXAMPLES:
    pg-pitr -d                                  # Restore to latest (end of WAL stream)
    pg-pitr -i                                  # Restore to backup completion time
    pg-pitr -t "2025-01-01 12:00:00+08"         # Restore to specific time
    pg-pitr -t "2025-01-01 04:00:00+00"         # Same time in UTC
    pg-pitr -n my-savepoint                     # Restore to named restore point
    pg-pitr -l "0/7C82CB8"                      # Restore to specific LSN
    pg-pitr -x 12345678 -X                      # Restore to right before transaction
    pg-pitr -S 20251225-120000F -i              # Restore specific backup, stop when consistent
    pg-pitr -S 20251225-120000F -t "2025-01-01 12:00:00+08"
    pg-pitr -D /tmp/data2 -c                    # Dry run to custom directory
    pg-pitr -t "2025-01-01 12:00:00+08" -T latest -v -c
    pg-pitr -t "2025-01-01 12:00:00+08" -c -- --repo=2

NOTES:
    - Run as postgres (dbsu) user, never as root
    - PostgreSQL must be stopped before restore
    - Time format: YYYY-MM-DD HH:MM:SS[.ssssss][+/-TZ]
    - Time without timezone is interpreted in the SERVER's timezone
    - In non-interactive mode (no tty), restore starts WITHOUT countdown
    - After restore, manually start PG, validate, then promote

EOF
    exit "${1:-0}"
}


#--------------------------------------------------------------#
# Log Util
#--------------------------------------------------------------#
if [[ -t 1 ]]; then
    __CN='\033[0m';__CK='\033[0;30m';__CR='\033[0;31m';__CG='\033[0;32m';
    __CY='\033[0;33m';__CB='\033[0;34m';__CM='\033[0;35m';__CC='\033[0;36m';__CW='\033[0;37m';
else
    __CN='';__CK='';__CR='';__CG='';__CY='';__CB='';__CM='';__CC='';__CW='';
fi
function log_info()  { printf "[${__CG} OK ${__CN}] ${__CG}%s${__CN}\n" "$*"; }
function log_warn()  { printf "[${__CY}WARN${__CN}] ${__CY}%s${__CN}\n" "$*"; }
function log_error() { printf "[${__CR}FAIL${__CN}] ${__CR}%s${__CN}\n" "$*"; }
function log_debug() { printf "[${__CB}HINT${__CN}] ${__CB}%s${__CN}\n" "$*"; }
function log_title() { printf "[${__CG}%s${__CN}] ${__CG}%s${__CN}\n" "$1" "$2"; }
function log_hint()  { printf "${__CB}%s${__CN}\n" "$*"; }
function log_line()  { printf "${__CM}===== %s =====${__CN}\n" "$*"; }


#--------------------------------------------------------------#
# Shell Command Formatting
#--------------------------------------------------------------#
shell_quote() {
    local value="${1-}"
    printf "'"
    while [[ "$value" == *"'"* ]]; do
        printf "%s'\\\\''" "${value%%\'*}"
        value="${value#*\'}"
    done
    printf "%s'" "$value"
}

shell_quote_arg() {
    local arg="$1"
    local key value

    if [[ "$arg" == --*=* ]]; then
        key="${arg%%=*}"
        value="${arg#*=}"
        if [[ "$value" =~ ^[A-Za-z0-9_./:@%+,-]+$ ]]; then
            printf "%s=%s" "$key" "$value"
        else
            printf "%s=%s" "$key" "$(shell_quote "$value")"
        fi
        return
    fi

    if [[ "$arg" =~ ^[A-Za-z0-9_./:@%+,-]+$ ]]; then
        printf "%s" "$arg"
    else
        shell_quote "$arg"
    fi
}

format_command() {
    local rendered="" quoted arg
    for arg in "$@"; do
        quoted="$(shell_quote_arg "$arg")"
        if [[ -z "$rendered" ]]; then
            rendered="$quoted"
        else
            rendered+=" $quoted"
        fi
    done
    printf "%s" "$rendered"
}

# Record which flag explicitly chose the recovery target, so a second
# choice (including -d, whose value equals the initial METHOD) is rejected
# instead of silently overriding the previous one.
METHOD_SET=""
set_method() {
    if [[ -n "$METHOD_SET" ]]; then
        log_error "Multiple recovery targets specified: $METHOD_SET and $1"
        exit 1
    fi
    METHOD_SET="$1"
    METHOD="$1"
}

OPTION_VALUE=""
require_option_value() {
    local option="$1"
    local label="$2"
    local value="${3-}"
    local inline=false

    if [[ "$option" == *=* ]]; then
        value="${option#*=}"
        option="${option%%=*}"
        inline=true
    fi

    if [[ -z "$value" ]] || [[ "$inline" != true && "$value" == -* ]]; then
        log_error "Missing $label for $option"
        exit 1
    fi

    OPTION_VALUE="$value"
}



#--------------------------------------------------------------#
# Default Parameters
#--------------------------------------------------------------#
METHOD="default"
TARGET=""
BACKUP_SET=""
DATA_DIR="/pg/data"
STANZA=""
TARGET_ACTION="pause"
TARGET_EXCLUSIVE=false
DRY_RUN=false
SKIP_CONFIRM=false
TARGET_TIMELINE=""
VERBOSE=false
EXTRA_ARGS=()


#--------------------------------------------------------------#
# Argument Parsing
#--------------------------------------------------------------#
# Print help if no arguments provided
[[ $# -eq 0 ]] && usage 0

while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            usage 0 ;;
        -D|--data|--data=*)
            if [[ "$1" == *=* ]]; then
                require_option_value "$1" "data directory"
            else
                require_option_value "$1" "data directory" "${2-}"; shift
            fi
            DATA_DIR="$OPTION_VALUE" ;;
        -s|--stanza|--stanza=*)
            if [[ "$1" == *=* ]]; then
                require_option_value "$1" "stanza name"
            else
                require_option_value "$1" "stanza name" "${2-}"; shift
            fi
            STANZA="$OPTION_VALUE" ;;
        -d|--default)
            set_method "default" ;;
        -i|--immediate)
            set_method "immediate" ;;
        -t|--time|--time=*)
            set_method "time"
            if [[ "$1" == *=* ]]; then
                require_option_value "$1" "timestamp"
            else
                require_option_value "$1" "timestamp" "${2-}"; shift
            fi
            TARGET="$OPTION_VALUE" ;;
        -n|--name|--name=*)
            set_method "name"
            if [[ "$1" == *=* ]]; then
                require_option_value "$1" "restore point name"
            else
                require_option_value "$1" "restore point name" "${2-}"; shift
            fi
            TARGET="$OPTION_VALUE" ;;
        -l|--lsn|--lsn=*)
            set_method "lsn"
            if [[ "$1" == *=* ]]; then
                require_option_value "$1" "LSN"
            else
                require_option_value "$1" "LSN" "${2-}"; shift
            fi
            TARGET="$OPTION_VALUE" ;;
        -x|--xid|--xid=*)
            set_method "xid"
            if [[ "$1" == *=* ]]; then
                require_option_value "$1" "XID"
            else
                require_option_value "$1" "XID" "${2-}"; shift
            fi
            TARGET="$OPTION_VALUE" ;;
        -S|--set|-b|--backup|-S=*|--set=*|-b=*|--backup=*)
            if [[ "$1" == *=* ]]; then
                require_option_value "$1" "backup set label"
            else
                require_option_value "$1" "backup set label" "${2-}"; shift
            fi
            [[ -n "$BACKUP_SET" ]] && { log_error "Multiple backup sets specified"; exit 1; }
            BACKUP_SET="$OPTION_VALUE" ;;
        -X|--exclusive|--target-exclusive)
            TARGET_EXCLUSIVE=true ;;
        -P|--promote|--target-action=promote)
            TARGET_ACTION="promote" ;;
        -T|--timeline)
            require_option_value "$1" "timeline" "${2-}"; shift
            TARGET_TIMELINE="$OPTION_VALUE" ;;
        --timeline=*|-T=*)
            require_option_value "$1" "timeline"
            TARGET_TIMELINE="$OPTION_VALUE" ;;
        -v|--verbose)
            VERBOSE=true ;;
        -c|--check|--dry-run)
            DRY_RUN=true ;;
        -y|--yes)
            SKIP_CONFIRM=true ;;
        --)
            EXTRA_ARGS+=("${@:2}")
            shift; break ;;
        -*)
            log_error "Unknown option: $1"; exit 1 ;;
        *)
            log_error "Unexpected argument: $1"
            log_hint "Use -- to pass additional pgBackRest options"
            exit 1 ;;
    esac
    shift
done


#--------------------------------------------------------------#
# Validation
#--------------------------------------------------------------#
# Check pgbackrest
if ! command -v pgbackrest &>/dev/null; then
    log_error "pgbackrest not found in PATH"
    exit 1
fi

# Check config file
PGBACKREST_CONF="/etc/pgbackrest/pgbackrest.conf"
if [[ ! -f "$PGBACKREST_CONF" ]]; then
    log_error "pgbackrest config not found: $PGBACKREST_CONF"
    exit 1
fi

# Auto-detect stanza if not specified
if [[ -z "$STANZA" ]]; then
    STANZA=$(sed -n 's/^\[\([^]:][^]:]*\)\].*/\1/p' "$PGBACKREST_CONF" | grep -vx 'global' | head -n1)
    if [[ -z "$STANZA" ]]; then
        log_error "Cannot auto-detect stanza from config: $PGBACKREST_CONF"
        exit 1
    fi
fi

# Validate data directory path
if [[ "$DATA_DIR" != /* ]]; then
    log_error "Data directory must be absolute path: $DATA_DIR"
    exit 1
fi

# Validate recovery target based on method
case "$METHOD" in
    time)
        # Accept: YYYY-MM-DD HH:MM:SS with optional .microseconds and optional timezone
        # Examples: "2025-01-01 12:00:00", "2025-01-01 12:00:00+08", "2025-01-01 12:00:00.123456+08:00"
        if [[ ! "$TARGET" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}[\ T][0-9]{2}:[0-9]{2}:[0-9]{2}(\.[0-9]+)?([+-][0-9]{2}(:[0-9]{2})?)?$ ]]; then
            log_error "Invalid time format: $TARGET"
            log_hint "Expected: YYYY-MM-DD HH:MM:SS[.usec][+/-TZ]"
            log_hint "Examples: 2025-01-01 12:00:00+08, 2025-01-01 04:00:00+00"
            exit 1
        fi
        if [[ ! "$TARGET" =~ [+-][0-9]{2}(:[0-9]{2})?$ ]]; then
            log_warn "No timezone in target time, will be interpreted in server timezone"
        fi
        ;;
    lsn)
        # LSN format: hex/hex (case insensitive)
        TARGET=$(echo "$TARGET" | tr '[:lower:]' '[:upper:]')
        if [[ ! "$TARGET" =~ ^[0-9A-F]{1,8}/[0-9A-F]{1,8}$ ]]; then
            log_error "Invalid LSN format: $TARGET"
            log_hint "Expected: X/X where X is 1-8 hex digits"
            log_hint "Example: 0/7C82CB8"
            exit 1
        fi
        ;;
    xid)
        if [[ ! "$TARGET" =~ ^[0-9]+$ ]] || [[ "$TARGET" -le 0 ]] || [[ "$TARGET" -ge 4294967296 ]]; then
            log_error "Invalid XID: $TARGET"
            log_hint "Expected: positive 32-bit integer (1 to 4294967295)"
            exit 1
        fi
        ;;
    name)
        if [[ -z "$TARGET" ]]; then
            log_error "Restore point name cannot be empty"
            exit 1
        fi
        ;;
esac

# Validate backup set selection, independent from recovery target.
if [[ -n "$BACKUP_SET" ]]; then
    if [[ "$BACKUP_SET" != "latest" ]] && [[ ! "$BACKUP_SET" =~ ^[0-9]{8}-[0-9]{6}F(_[0-9]{8}-[0-9]{6}(D|I))?$ ]]; then
        log_error "Invalid backup set label: $BACKUP_SET"
        log_hint "Expected: 'latest' or backup label like 20251225-120000F"
        log_hint "Check available backups with: pgbackrest info --stanza=$STANZA"
        exit 1
    fi
fi

# Validate timeline syntax early. pgBackRest accepts "latest", "current", or a numeric timeline.
if [[ -n "$TARGET_TIMELINE" ]]; then
    if [[ "$TARGET_TIMELINE" != "latest" ]] && [[ "$TARGET_TIMELINE" != "current" ]] && [[ ! "$TARGET_TIMELINE" =~ ^[1-9][0-9]*$ ]]; then
        log_error "Invalid timeline: $TARGET_TIMELINE"
        log_hint "Expected: 'latest', 'current', or a positive integer"
        exit 1
    fi
fi

if [[ -n "$BACKUP_SET" ]] && [[ "$METHOD" == "default" ]]; then
    log_hint "--set without recovery target still replays WAL to the end of stream"
    log_hint "Combine with -i to stop right after this backup becomes consistent"
fi


#--------------------------------------------------------------#
# Build Command
#--------------------------------------------------------------#
CMD_ARGS=("--stanza=$STANZA" "--delta" "--force")

# Add data directory if not default
if [[ "$DATA_DIR" != "/pg/data" ]]; then
    CMD_ARGS+=("--pg1-path=$DATA_DIR")
fi

# Add backup set selection if specified.
if [[ -n "$BACKUP_SET" ]]; then
    CMD_ARGS+=("--set=$BACKUP_SET")
fi

# Add recovery target
case "$METHOD" in
    default)
        ;; # No additional args needed
    immediate)
        CMD_ARGS+=("--type=immediate")
        ;;
    time)
        CMD_ARGS+=("--type=time" "--target=$TARGET")
        ;;
    name)
        CMD_ARGS+=("--type=name" "--target=$TARGET")
        ;;
    lsn)
        CMD_ARGS+=("--type=lsn" "--target=$TARGET")
        ;;
    xid)
        CMD_ARGS+=("--type=xid" "--target=$TARGET")
        ;;
esac

# Add exclusive option
if [[ "$TARGET_EXCLUSIVE" == true ]]; then
    CMD_ARGS+=("--target-exclusive")
fi

# Add target action (only for specific recovery types)
if [[ "$TARGET_ACTION" == "promote" ]] && [[ "$METHOD" =~ ^(time|name|lsn|xid|immediate)$ ]]; then
    CMD_ARGS+=("--target-action=promote")
fi

# Add timeline / verbosity options
if [[ -n "$TARGET_TIMELINE" ]]; then
    CMD_ARGS+=("--target-timeline=$TARGET_TIMELINE")
fi

if [[ "$VERBOSE" == true ]]; then
    CMD_ARGS+=("--log-level-console=info")
fi

# Final command
if [[ ${#EXTRA_ARGS[@]} -gt 0 ]]; then
    FULL_CMD="$(format_command pgbackrest "${CMD_ARGS[@]}" "${EXTRA_ARGS[@]}" restore)"
else
    FULL_CMD="$(format_command pgbackrest "${CMD_ARGS[@]}" restore)"
fi


#--------------------------------------------------------------#
# Pre-flight Checks
#--------------------------------------------------------------#
log_info "Recovery Target: $METHOD${TARGET:+ ($TARGET)}"
[[ -n "$BACKUP_SET" ]] && log_info "Backup Set:      $BACKUP_SET"
log_info "Data Directory:  $DATA_DIR"
log_info "Stanza:          $STANZA"
log_info "Options:         exclusive=$TARGET_EXCLUSIVE action=$TARGET_ACTION"
log_hint ""
log_hint "Command:"
log_hint "  $FULL_CMD"
log_hint ""

# Dry run - just print and exit
if [[ "$DRY_RUN" == true ]]; then
    log_warn "[CHECK] Command printed above. Run without -c to execute."
    exit 0
fi

if [[ "$(id -u)" -eq 0 ]]; then
    log_error "Do not run restore as root, run as the database superuser instead"
    log_hint "sudo -iu postgres $PROG_NAME ..."
    exit 1
fi

# Check if current user is in postgres group
if ! id -nG | grep -qw postgres; then
    log_warn "Current user $(whoami) is not in postgres group"
fi

# Check if PostgreSQL is running in the target directory
if [[ -f "$DATA_DIR/postmaster.pid" ]]; then
    PG_PID=$(head -1 "$DATA_DIR/postmaster.pid" 2>/dev/null)
    if [[ -n "$PG_PID" ]] && kill -0 "$PG_PID" 2>/dev/null; then
        log_error "PostgreSQL is still running in $DATA_DIR (PID: $PG_PID)"
        log_hint "Stop it before restore: pg_ctl -D $DATA_DIR stop -m fast"
        exit 1
    fi
    if [[ -n "$PG_PID" ]]; then
        log_error "Stale postmaster.pid found in $DATA_DIR (process $PG_PID not running)"
    else
        log_error "postmaster.pid found in $DATA_DIR (PID is empty)"
    fi
    log_hint "pgBackRest refuses to restore while postmaster.pid exists"
    log_hint "Remove it only after verifying PostgreSQL is stopped"
    exit 1
fi


#--------------------------------------------------------------#
# Confirmation & Execution
#--------------------------------------------------------------#
log_warn "==========================================="
log_warn "WARNING: Point-In-Time Recovery Operation"
log_warn "This will OVERWRITE data in: $DATA_DIR"
log_warn "==========================================="

#--------------------------------------------------------------#
# Countdown
#--------------------------------------------------------------#
# Countdown timer for interactive terminals
countdown() {
    local seconds=${1:-5}
    if [ -t 0 ] && [ -t 1 ]; then
        for ((i=seconds; i>0; i--)); do
            printf "\r${__CY}Starting in %d seconds... (Ctrl+C to abort)${__CN}" "$i"
            sleep 1
        done
        printf "\n"
    else
        log_info "Non-interactive mode, skipping countdown..."
    fi
}

if [[ "$SKIP_CONFIRM" != true ]] && [ -t 0 ] && [ -t 1 ]; then
    log_hint "Press Ctrl+C to abort"
    countdown 5
fi

log_info "Starting restore..."
log_hint "$ $FULL_CMD"

# Execute the restore command (using array to avoid eval security risks)
if [[ ${#EXTRA_ARGS[@]} -gt 0 ]]; then
    pgbackrest "${CMD_ARGS[@]}" "${EXTRA_ARGS[@]}" restore
else
    pgbackrest "${CMD_ARGS[@]}" restore
fi
RC=$?

if [[ $RC -eq 0 ]]; then
    log_info "==========================================="
    log_info "Restore completed successfully!"
    log_info "==========================================="
    log_hint ""
    log_hint "Next steps:"
    log_hint "  1. Start PostgreSQL:    pg_ctl -D $DATA_DIR start"
    log_hint "  2. Validate your data"
    log_hint "  3. Promote if satisfied: pg_ctl -D $DATA_DIR promote"
    log_hint "  4. Enable archive_mode:  psql -c \"ALTER SYSTEM SET archive_mode = on;\""
    log_hint "  5. Restart PostgreSQL:   pg_ctl -D $DATA_DIR restart"
else
    log_error "Restore failed with exit code: $RC"
    log_hint "Check pgbackrest logs (log-path in $PGBACKREST_CONF) for details"
fi

exit $RC
