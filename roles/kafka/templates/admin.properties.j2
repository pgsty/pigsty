{% if kafka_security == 'scram' %}
security.protocol=SASL_SSL
sasl.mechanism=SCRAM-SHA-512
sasl.jaas.config=org.apache.kafka.common.security.scram.ScramLoginModule required username="{{ kafka_admin_principal_internal }}" password="{{ kafka_admin_password_internal }}";
ssl.truststore.type=PEM
ssl.truststore.location=/etc/pki/ca.crt
ssl.endpoint.identification.algorithm=https
{% else %}
security.protocol=PLAINTEXT
{% endif %}
