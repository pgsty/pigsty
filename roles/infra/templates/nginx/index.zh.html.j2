<!DOCTYPE html>
<html lang="zh-CN" class="no-js">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Pigsty - 开箱即用的开源 PostgreSQL RDS">
    <title>Pigsty {{ version }}</title>
    <script>
        // apply stored / preferred theme before first paint
        (function () {
            var t = null;
            try { t = localStorage.getItem('pigsty-landing-theme'); } catch (e) {}
            if (t !== 'light' && t !== 'dark') {
                t = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
            }
            document.documentElement.setAttribute('data-theme', t);
            document.documentElement.classList.remove('no-js');
            document.documentElement.classList.add('js');
        })();
    </script>
    <style>
        /* Chakra Petch 700 — subset embedded (glyphs: "PIGSTY PostgreSQL In Great STYle", 1.4 KB) */
        @font-face {
            font-family: 'Chakra Petch';
            font-style: normal;
            font-weight: 700;
            src: url(data:font/woff2;base64,) format('woff2');
        }
        /* ============================================================
           Pigsty Portal — "The Powered Board"
           dark  = powered circuit board (blue-black solder mask)
           light = printed engineering datasheet (cool paper)
           brand hexagon palette:
           P #2f6793 · I #419edb · G #ffa269 · S #6f747c · T #de372c · Y #53ac79
           ============================================================ */
        :root {
            --brand-p: #2f6793; --brand-i: #419edb; --brand-g: #ffa269;
            --brand-s: #6f747c; --brand-t: #de372c; --brand-y: #53ac79;
            --font-sans: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            --font-mono: ui-monospace, "SF Mono", "Cascadia Mono", Menlo, Consolas, "Liberation Mono", monospace;
            --font-display: 'Chakra Petch', var(--font-sans);
            --radius-sm: 8px; --radius-md: 12px;
        }
        html[data-theme="dark"] {
            color-scheme: dark;
            --bg: #0b1119; --bg-elev: #121c29; --bg-elev-2: #182435;
            --line: rgba(148, 176, 210, 0.16); --line-strong: rgba(148, 176, 210, 0.32);
            --ink: #e8eef6; --ink-soft: #b6c2d2; --ink-mute: #7f8da1; --silk: #93a3b8;
            --pg: #5da2dd; --pg-strong: #7fb8e8;
            --copper: #e0a35c; --copper-dim: rgba(224, 163, 92, 0.55);
            --ok: #55c98a;
            --grid-line: rgba(120, 150, 190, 0.055);
            --trace: rgba(224, 163, 92, 0.28);
            --btn-bg: #2f6793; --btn-bg-hover: #3a7cae; --btn-ink: #f2f7fc;
            --header-bg: rgba(11, 17, 25, 0.92);
            --shadow-sm: 0 4px 18px rgba(2, 8, 18, 0.35);
            --shadow-md: 0 14px 44px rgba(2, 8, 18, 0.45);
            --glow-blue: rgba(65, 158, 219, 0.14);
            --hl: rgba(93, 162, 221, 0.08);
            --card-hover-border: rgba(224, 163, 92, 0.5);
        }
        html[data-theme="light"] {
            color-scheme: light;
            --bg: #f1f4f8; --bg-elev: #ffffff; --bg-elev-2: #f6f9fc;
            --line: rgba(48, 74, 105, 0.14); --line-strong: rgba(48, 74, 105, 0.3);
            --ink: #16222e; --ink-soft: #3d4e61; --ink-mute: #66788c; --silk: #5d7189;
            --pg: #2b6ca3; --pg-strong: #1d588c;
            --copper: #b4762e; --copper-dim: rgba(180, 118, 46, 0.6);
            --ok: #178a53;
            --grid-line: rgba(47, 103, 147, 0.06);
            --trace: rgba(180, 118, 46, 0.35);
            --btn-bg: #2f6793; --btn-bg-hover: #275a82; --btn-ink: #ffffff;
            --header-bg: rgba(241, 244, 248, 0.88);
            --shadow-sm: 0 2px 10px rgba(23, 42, 66, 0.08);
            --shadow-md: 0 12px 34px rgba(23, 42, 66, 0.12);
            --glow-blue: rgba(65, 158, 219, 0.12);
            --hl: rgba(47, 103, 147, 0.07);
            --card-hover-border: rgba(180, 118, 46, 0.55);
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
        body {
            font-family: var(--font-sans);
            font-size: 16px; line-height: 1.6;
            color: var(--ink); background: var(--bg);
            min-height: 100vh; display: flex; flex-direction: column;
        }
        /* copper-grid backdrop */
        body::before {
            content: ''; position: fixed; inset: 0; z-index: -1; pointer-events: none;
            background-image:
                linear-gradient(var(--grid-line) 1px, transparent 1px),
                linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
            background-size: 44px 44px;
        }
        a { color: inherit; text-decoration: none; }
        main { flex: 1 0 auto; }
        .container { width: 100%; max-width: 1200px; margin: 0 auto; padding: 0 24px; }

        /* silkscreen labels */
        .silk {
            font-family: var(--font-mono);
            font-size: 0.7rem; font-weight: 500;
            letter-spacing: 0.16em; text-transform: uppercase;
            color: var(--silk);
        }
        .sec-head { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
        .sec-head .silk { flex: none; white-space: nowrap; }
        .sec-toggle {
            flex: none; display: inline-flex; align-items: center; gap: 8px;
            border: none; background: transparent; padding: 0; cursor: pointer;
            color: var(--silk); transition: color 150ms ease;
        }
        .sec-toggle:hover { color: var(--copper); }
        .sec-toggle:hover .silk { color: var(--copper); }
        .sec-toggle svg {
            width: 14px; height: 14px;
            stroke: currentColor; stroke-width: 2; fill: none;
            stroke-linecap: round; stroke-linejoin: round;
            transform: rotate(180deg); transition: transform 200ms ease;
        }
        .sec-toggle.collapsed svg { transform: rotate(0deg); }
        .collapse-wrap {
            max-height: 4000px; opacity: 1;
            transition: max-height 300ms ease, opacity 300ms ease, border-width 300ms ease;
        }
        .collapse-wrap.collapsed { max-height: 0; opacity: 0; overflow: hidden; border-width: 0; }
        .sec-head .silk::before {
            content: ''; display: inline-block; width: 8px; height: 8px;
            margin-right: 10px; border: 1.5px solid var(--copper); border-radius: 50%;
        }
        .eyebrow-trace {
            flex: 1; height: 1px; min-width: 40px; position: relative;
            background: linear-gradient(90deg, var(--trace), transparent 92%);
        }
        .eyebrow-trace::before {
            content: ''; position: absolute; left: 38%; top: -2.5px;
            width: 6px; height: 6px; border-radius: 50%;
            border: 1.5px solid var(--copper-dim); background: var(--bg);
        }

        /* ========================================
           Header
           ======================================== */
        .header {
            position: sticky; top: 0; z-index: 100;
            background: var(--header-bg);
            -webkit-backdrop-filter: blur(14px); backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--line);
            transition: box-shadow 200ms ease;
        }
        .header.scrolled { box-shadow: var(--shadow-sm); }
        .header-inner { display: flex; align-items: center; justify-content: space-between; height: 62px; }
        .logo { display: flex; align-items: center; gap: 11px; }
        .logo-icon { width: 30px; height: 30px; }
        .logo-icon svg { width: 100%; height: 100%; display: block; }
        .logo-text {
            font-family: var(--font-display);
            font-weight: 700; font-size: 1.32rem; letter-spacing: 0.18em; line-height: 1;
            color: var(--ink);
        }
        .nav { display: flex; align-items: center; gap: 6px; }
        .nav-link {
            padding: 8px 13px; border-radius: 6px;
            font-size: 0.93rem; font-weight: 500; color: var(--ink-soft);
            transition: color 150ms ease, background 150ms ease;
        }
        .nav-link:hover { color: var(--ink); background: var(--bg-elev); }
        .nav-icon {
            display: inline-flex; align-items: center; justify-content: center;
            min-width: 36px; height: 36px; border: none; border-radius: 6px;
            background: transparent; color: var(--ink-mute); cursor: pointer;
            transition: color 150ms ease, background 150ms ease;
        }
        .nav-icon:hover { color: var(--ink); background: var(--bg-elev); }
        .nav-icon svg { width: 18px; height: 18px; display: block; }
        html[data-theme="dark"] .icon-moon { display: none; }
        html[data-theme="light"] .icon-sun { display: none; }

        /* hover mega-dropdowns (mirrors the docs site nav) */
        .nav-item { position: relative; }
        .caret {
            width: 10px; height: 10px; margin-left: 4px; vertical-align: -1px;
            stroke: currentColor; stroke-width: 2.5; fill: none;
            stroke-linecap: round; stroke-linejoin: round;
            opacity: 0.55; transition: transform 180ms ease;
        }
        .nav-item:hover .caret,
        .nav-item:focus-within .caret { transform: rotate(180deg); }
        .nav-dropdown {
            position: absolute; top: calc(100% + 10px); left: 50%; z-index: 110;
            display: flex; gap: 14px;
            width: max-content; max-width: min(94vw, 880px);
            padding: 14px 16px;
            border: 1px solid var(--line-strong); border-radius: var(--radius-md);
            background: var(--bg-elev); box-shadow: var(--shadow-md);
            opacity: 0; visibility: hidden; transform: translate(-50%, 8px);
            transition: opacity 180ms ease, transform 180ms ease, visibility 0s linear 180ms;
        }
        /* hover bridge over the gap */
        .nav-dropdown::before { content: ''; position: absolute; left: 0; right: 0; top: -14px; height: 14px; }
        .nav-item:hover .nav-dropdown,
        .nav-item:focus-within .nav-dropdown {
            opacity: 1; visibility: visible; transform: translate(-50%, 0);
            transition: opacity 180ms ease, transform 180ms ease, visibility 0s;
        }
        .dd-title { margin: 0 0 8px; padding-left: 9px; font-size: 0.64rem; color: var(--copper); }
        .dd-cols { display: flex; gap: 2px; }
        .dd-col { margin: 0; padding: 0; list-style: none; }
        .dd-col a {
            display: flex; align-items: center; gap: 9px;
            height: 33px; padding: 0 9px; border-radius: 6px;
            font-size: 0.86rem; font-weight: 500; line-height: 1;
            color: var(--ink-soft); white-space: nowrap;
            transition: background 140ms ease, color 140ms ease;
        }
        .dd-col a:hover { background: var(--bg-elev-2); color: var(--ink); }
        .di {
            flex: none; width: 16px; height: 16px;
            stroke: currentColor; stroke-width: 1.8; fill: none;
            stroke-linecap: round; stroke-linejoin: round;
            color: var(--silk); transition: color 140ms ease;
        }
        .dd-col a:hover .di { color: var(--copper); }
        .dd-mono .dd-col a { font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.04em; }
        .dd-sep { flex: none; width: 1px; align-self: stretch; background: var(--line); }

        /* ========================================
           Hero
           ======================================== */
        .hero { position: relative; padding: clamp(40px, 5vw, 72px) 0 clamp(16px, 2vw, 28px); overflow: hidden; }
        .hero::before {
            content: ''; position: absolute; inset: 0; z-index: -1; pointer-events: none;
            background: radial-gradient(48% 42% at 78% 20%, var(--glow-blue), transparent 70%);
        }
        .hero-eyebrow { display: flex; flex-wrap: wrap; align-items: center; gap: 8px 14px; margin-bottom: 20px; }
        .status-dot {
            width: 9px; height: 9px; border-radius: 50%;
            background: var(--ok); box-shadow: 0 0 0 3px rgba(85, 201, 138, 0.18);
            animation: breathe 2.6s ease-in-out infinite;
        }
        @keyframes breathe {
            0%, 100% { box-shadow: 0 0 0 3px rgba(85, 201, 138, 0.18); }
            50% { box-shadow: 0 0 0 6px rgba(85, 201, 138, 0.06); }
        }
        .version-link {
            margin-left: 8px;
            font-family: var(--font-mono); font-size: 0.82em; letter-spacing: 0.03em;
            color: var(--copper);
            border-bottom: 1px dashed var(--copper-dim);
            transition: border-color 150ms ease;
        }
        .version-link:hover { border-bottom-style: solid; border-bottom-color: var(--copper); }
        .hero-title {
            margin-bottom: 12px;
            font-family: var(--font-display);
            font-size: clamp(2.1rem, 5vw, 3.4rem);
            font-weight: 700; line-height: 1.12; letter-spacing: 0.005em;
            color: var(--ink);
        }
        .ini { font-style: normal; }
        .ini-p { color: var(--brand-p); } .ini-i { color: var(--brand-i); }
        .ini-g { color: var(--brand-g); } .ini-s { color: var(--brand-s); }
        .ini-t { color: var(--brand-t); } .ini-y { color: var(--brand-y); }
        html[data-theme="dark"] .ini-p { color: #4d89ba; }
        html[data-theme="dark"] .ini-s { color: #8b93a0; }
        .hero-sub { margin-bottom: 26px; font-size: clamp(1rem, 1.4vw, 1.15rem); color: var(--ink-soft); }
        .hero-actions { display: flex; flex-wrap: wrap; gap: 13px; }
        .btn {
            display: inline-flex; align-items: center; gap: 9px;
            padding: 12px 24px; border: 1px solid transparent; border-radius: var(--radius-sm);
            font-size: 0.98rem; font-weight: 700; line-height: 1; cursor: pointer;
            transition: transform 150ms ease, background 150ms ease, border-color 150ms ease, color 150ms ease, box-shadow 150ms ease;
        }
        .btn svg { width: 17px; height: 17px; }
        .btn-primary { background: var(--btn-bg); color: var(--btn-ink); box-shadow: 0 6px 22px rgba(47, 103, 147, 0.35); }
        .btn-primary:hover { background: var(--btn-bg-hover); transform: translateY(-2px); }
        .btn-ghost { background: transparent; border-color: var(--line-strong); color: var(--ink); }
        .btn-ghost:hover { border-color: var(--pg); color: var(--pg-strong); transform: translateY(-2px); }

        /* ========================================
           Services
           ======================================== */
        .section { padding: clamp(18px, 2.5vw, 32px) 0; }
        .svc-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; }
        .svc-card {
            position: relative; display: flex; align-items: center; gap: 14px;
            padding: 17px 18px;
            border: 1px solid var(--line); border-radius: var(--radius-md);
            background: var(--bg-elev);
            transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
        }
        /* chip pin-1 mark */
        .svc-card::before {
            content: ''; position: absolute; top: 9px; left: 9px;
            width: 5px; height: 5px; border-radius: 50%;
            background: var(--line-strong); transition: background 180ms ease;
        }
        .svc-card:hover {
            transform: translateY(-3px);
            border-color: var(--card-hover-border);
            box-shadow: var(--shadow-md);
        }
        .svc-card:hover::before { background: var(--copper); }
        .svc-icon {
            flex: none; display: flex; align-items: center; justify-content: center;
            width: 44px; height: 44px; border-radius: 10px;
            background: linear-gradient(135deg, rgba(65, 158, 219, 0.16), rgba(65, 158, 219, 0.05));
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.07);
            color: var(--pg);
        }
        html[data-theme="light"] .svc-icon {
            background: linear-gradient(135deg, rgba(47, 103, 147, 0.12), rgba(47, 103, 147, 0.04));
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
        }
        .svc-icon svg { width: 21px; height: 21px; stroke: currentColor; stroke-width: 2; fill: none; }
        .svc-body {
            flex: 1; min-width: 0; min-height: 44px;
            display: flex; flex-direction: column; justify-content: center;
        }
        .svc-name {
            display: block; font-size: 0.95rem; font-weight: 700; color: var(--ink); line-height: 1.35;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .svc-desc {
            display: block; font-size: 0.78rem; color: var(--ink-mute); line-height: 1.4; margin-top: 2px;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .svc-arrow {
            position: absolute; top: 16px; right: 15px;
            width: 16px; height: 16px; color: var(--copper);
            opacity: 0; transform: translateX(-6px);
            transition: opacity 180ms ease, transform 180ms ease;
        }
        .svc-card:hover .svc-arrow { opacity: 1; transform: translateX(0); }

        /* ========================================
           Topology Matrix
           ======================================== */
        .tp-section { padding: clamp(18px, 2.5vw, 32px) 0 clamp(40px, 5vw, 64px); }
        .tp-wrapper {
            overflow-x: auto; -webkit-overflow-scrolling: touch;
            border: 1px solid var(--line); border-radius: var(--radius-md);
            background: var(--bg-elev); box-shadow: var(--shadow-sm);
        }
        .tp-table { width: 100%; min-width: 640px; border-collapse: collapse; }
        .tp-table th {
            padding: 12px 14px; text-align: center;
            font-family: var(--font-mono); font-size: 0.72rem; font-weight: 600;
            letter-spacing: 0.14em; text-transform: uppercase;
            color: var(--silk); background: var(--bg-elev-2);
            border-bottom: 1px solid var(--line-strong);
            cursor: pointer; transition: color 150ms ease, background 150ms ease;
        }
        .tp-table th:hover { color: var(--copper); }
        .tp-table td {
            padding: 9px 14px; text-align: center;
            border-bottom: 1px solid var(--line);
            transition: background 120ms ease;
        }
        .tp-table tr:last-child td { border-bottom: none; }
        .tp-table th.hl, .tp-table td.hl, .tp-table tr.hl td { background: var(--hl); }
        .tp-ip {
            display: inline-block; padding: 3px 10px; border-radius: 6px;
            font-family: var(--font-mono); font-size: 0.85rem; font-weight: 500;
            color: var(--ink); transition: color 150ms ease, background 150ms ease;
        }
        .tp-ip:hover { color: var(--pg-strong); background: var(--hl); }
        /* 管理节点：铜色加粗 + Pin-1 圆点标记 + 悬停丝印提示 */
        .tp-ip.tp-admin { position: relative; color: var(--copper); font-weight: 700; }
        .tp-ip.tp-admin:hover { color: var(--copper); background: rgba(224, 163, 92, 0.1); }
        .admin-tip {
            position: absolute; left: 50%; bottom: calc(100% + 8px);
            transform: translate(-50%, 3px);
            padding: 4px 11px;
            border: 1px solid var(--copper-dim); border-radius: 6px;
            background: var(--bg-elev); box-shadow: var(--shadow-md);
            font-family: var(--font-mono); font-size: 0.68rem; font-weight: 500;
            letter-spacing: 0.08em; color: var(--copper);
            white-space: nowrap; opacity: 0; pointer-events: none;
            transition: opacity 150ms ease, transform 150ms ease;
            z-index: 5;
        }
        .admin-tip::after {
            content: ''; position: absolute; top: 100%; left: 50%;
            transform: translateX(-50%);
            border: 4px solid transparent; border-top-color: var(--copper-dim);
        }
        .tp-ip.tp-admin:hover .admin-tip { opacity: 1; transform: translate(-50%, 0); }
        .tp-pill {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 3px 12px; border: 1px solid var(--line); border-radius: 999px;
            font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.02em;
            color: var(--ink-soft); white-space: nowrap;
            transition: border-color 150ms ease, color 150ms ease, transform 150ms ease;
        }
        a.tp-pill:hover { border-color: var(--copper); color: var(--ink); transform: translateY(-1px); }
        .tp-pill.empty { border-color: transparent; color: var(--ink-mute); opacity: 0.5; }
        /* per-cluster hue assigned by JS via --ch / --cs */
        .tp-pill.pg {
            font-weight: 600;
            background: hsl(var(--ch, 210) var(--cs, 45%) 60% / 0.13);
            border-color: hsl(var(--ch, 210) var(--cs, 45%) 60% / 0.42);
            color: hsl(var(--ch, 210) var(--cs, 45%) 72%);
        }
        html[data-theme="light"] .tp-pill.pg {
            background: hsl(var(--ch, 210) var(--cs, 45%) 50% / 0.09);
            border-color: hsl(var(--ch, 210) var(--cs, 45%) 45% / 0.45);
            color: hsl(var(--ch, 210) var(--cs, 45%) 30%);
        }
        a.tp-pill.pg:hover { border-color: hsl(var(--ch, 210) var(--cs, 45%) 55%); }

        /* ========================================
           Footer
           ======================================== */
        .footer {
            flex-shrink: 0;
            border-top: 1px solid var(--line);
            background: var(--bg-elev);
            padding: clamp(40px, 5vw, 60px) 0 26px;
        }
        html[data-theme="light"] .footer { background: #e9eef4; }
        .footer-grid {
            display: grid; grid-template-columns: 2fr repeat(4, 1fr);
            gap: 32px 24px; margin-bottom: 38px;
        }
        .footer-logo { display: inline-flex; align-items: center; gap: 10px; margin-bottom: 14px; }
        .footer-logo .logo-icon { width: 28px; height: 28px; }
        .footer-logo .logo-text { font-size: 1.05rem; }
        .footer-desc { color: var(--ink-soft); font-size: 0.9rem; line-height: 1.75; }
        .footer-desc b { font-weight: 700; }
        .footer-slogan { margin-top: 10px; color: var(--ink-mute); font-size: 0.88rem; }
        .footer-slogan .hl-good { color: var(--copper); font-weight: 700; }
        .footer-slogan .hl-use { color: var(--pg-strong); font-weight: 700; }
        .footer-title { margin-bottom: 14px; }
        .footer-links { list-style: none; }
        .footer-links li { margin-bottom: 9px; }
        .footer-links a { color: var(--ink-soft); font-size: 0.9rem; transition: color 150ms ease; }
        .footer-links a:hover { color: var(--pg-strong); }
        .footer-bottom {
            display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
            gap: 12px 24px; padding-top: 20px;
            border-top: 1px solid var(--line);
            font-size: 0.82rem; color: var(--ink-mute);
        }
        .footer-bottom a { color: var(--ink-soft); transition: color 150ms ease; }
        .footer-bottom a:hover { color: var(--pg-strong); }
        .footer-right { display: flex; align-items: center; gap: 18px; }
        .footer-lang { display: flex; gap: 10px; font-size: 0.8rem; }
        .footer-lang a { color: var(--ink-soft); }
        .footer-lang a:hover { color: var(--pg-strong); }
        .footer-git { display: inline-flex; color: var(--ink-mute); transition: color 150ms ease; }
        .footer-git:hover { color: var(--ink); }
        .footer-git svg { width: 18px; height: 18px; }

        /* ========================================
           Reveal & Responsive
           ======================================== */
        html.js .reveal { opacity: 0; transform: translateY(14px); transition: opacity 500ms ease, transform 500ms ease; }
        html.js .reveal.on { opacity: 1; transform: none; }
        @media (prefers-reduced-motion: reduce) {
            html.js .reveal { opacity: 1; transform: none; transition: none; }
            .status-dot { animation: none; }
        }
        @media (max-width: 900px) {
            .svc-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .footer-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .footer-brand { grid-column: 1 / -1; }
        }
        @media (max-width: 760px) {
            .nav .nav-item, .nav .nav-link { display: none; }
        }
        @media (max-width: 560px) {
            .container { padding: 0 16px; }
            .svc-grid { grid-template-columns: minmax(0, 1fr); }
            .hero-actions .btn { flex: 1; justify-content: center; }
            .footer-bottom { flex-direction: column; text-align: center; }
        }
    </style>
