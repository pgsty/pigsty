                <span class="status-dot" aria-hidden="true"></span>
                <span class="silk">OPEN-SOURCE POSTGRESQL DISTRIBUTION</span>
            </p>
            <h1 class="hero-title">
                <b class="ini ini-p">P</b>ostgreSQL <b class="ini ini-i">I</b>n <b class="ini ini-g">G</b>reat <b class="ini ini-s">S</b><b class="ini ini-t">T</b><b class="ini ini-y">Y</b>le
            </h1>
            <p class="hero-sub">开箱即用、本地优先、自主可控的企业级开源 PostgreSQL 数据库发行版<a href="https://pigsty.cc/docs/about/release/#{{ version | replace('.', '') }}" class="version-link">{{ version }}</a></p>
            <div class="hero-actions">
                <a href="/ui/d/pigsty" class="btn btn-primary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    监控面板
                </a>
                <a href="https://pigsty.cc/docs" class="btn btn-ghost">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    参阅文档
                </a>
            </div>
        </div>
    </section>

    <!-- Services -->
    <section class="section">
        <div class="container">
            <div class="sec-head">
                <button type="button" class="sec-toggle" data-target="svcWrap" aria-expanded="true" aria-label="收起或展开服务入口">
                    <span class="silk">服务入口</span>
                    <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                <span class="eyebrow-trace" aria-hidden="true"></span>
            </div>
            <div class="collapse-wrap" id="svcWrap">
            <div class="svc-grid">
{% for svc in (infra_services | default([])) + (infra_extra_services | default([])) %}
                <a href="{{ svc.url }}" class="svc-card reveal" title="{{ svc.desc_cn | default(svc.desc) | default('') }}">
                    <span class="svc-icon">
{% set icon = svc.icon | default('link') %}
{% if icon == 'metrics' %}
                        <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
{% elif icon == 'logs' %}
                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
{% elif icon == 'traces' %}
                        <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
{% elif icon == 'discovery' %}
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
{% elif icon == 'target' %}
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
{% elif icon == 'alert' %}
                        <svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><circle cx="12" cy="17" r="0.5" fill="currentColor"/></svg>
{% elif icon == 'alertmgr' %}
                        <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
{% elif icon == 'database' %}
                        <svg viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
{% elif icon == 'file' %}
                        <svg viewBox="0 0 24 24"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
{% elif icon == 'activity' %}
                        <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
{% elif icon == 'lock' %}
                        <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
{% elif icon == 'package' %}
                        <svg viewBox="0 0 24 24"><path d="M16.5 9.4l-9-5.19M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
{% elif icon == 'search' %}
                        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
{% elif icon == 'code' %}
                        <svg viewBox="0 0 24 24"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
{% elif icon == 'jupyter' %}
                        <svg viewBox="0 0 24 24"><circle cx="4.5" cy="4.5" r="2"/><circle cx="19.5" cy="19.5" r="2"/><circle cx="19.5" cy="4.5" r="1.5" fill="currentColor"/><ellipse cx="12" cy="12" rx="9" ry="5" transform="rotate(-30 12 12)"/></svg>
{% elif icon == 'claude' %}
                        <svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2L9.5 9.5L2 12l7.5 2.5L12 22l2.5-7.5L22 12l-7.5-2.5L12 2z"/></svg>
{% else %}
                        <svg viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
{% endif %}
                    </span>
                    <span class="svc-body">
                        <span class="svc-name">{{ svc.name_cn | default(svc.name) | default('Service') }}</span>
                        <span class="svc-desc">{{ svc.desc_cn | default(svc.desc) | default('') }}</span>
                    </span>
                    <svg class="svc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
{% endfor %}
            </div>
            </div>
        </div>
    </section>

    <!-- Topology Matrix -->
    <section class="tp-section">
        <div class="container">
            <div class="sec-head">
                <button type="button" class="sec-toggle" data-target="topologyWrapper" aria-expanded="true" aria-label="收起或展开节点清单">
                    <span class="silk">节点清单</span>
                    <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                <span class="eyebrow-trace" aria-hidden="true"></span>
            </div>
            <div class="tp-wrapper collapse-wrap" id="topologyWrapper">
                <table class="tp-table" id="topologyTable">
                    <thead>
                        <tr>
                            <th data-col="node"><a href="/ui/d/node-overview">NODE</a></th>
                            <th data-col="pgsql"><a href="/ui/d/pgsql-overview">PGSQL</a></th>
                            <th data-col="infra"><a href="/ui/d/infra-overview">INFRA</a></th>
                            <th data-col="etcd"><a href="/ui/d/etcd-overview">ETCD</a></th>
                            <th data-col="minio"><a href="/ui/d/minio-overview">MINIO</a></th>
                        </tr>
                    </thead>
                    <tbody>
{% set nodes_list = [] %}
{% set pg_clusters = {} %}
{% set seen_hosts = {} %}
{% for host in groups['all'] | default([]) | sort %}
{%   if host not in seen_hosts %}
{%     set _ = seen_hosts.update({host: true}) %}
{%     set node_info = hostvars[host] | default({}) %}
{%     set pg_cluster = node_info.pg_cluster | default('') %}
{%     set pg_seq = node_info.pg_seq | default('') %}
{%     if pg_cluster and pg_cluster not in pg_clusters %}
{%       set _ = pg_clusters.update({pg_cluster: pg_clusters | length}) %}
{%     endif %}
{%     set _ = nodes_list.append({
          'ip': host,
          'nodename': node_info.nodename | default(host),
          'pg_cluster': pg_cluster,
          'pg_seq': pg_seq,
          'infra_seq': node_info.infra_seq | default(''),
          'etcd_seq': node_info.etcd_seq | default(''),
          'minio_cluster': node_info.minio_cluster | default(''),
          'minio_seq': node_info.minio_seq | default('')
        }) %}
{%   endif %}
{% endfor %}
{% for node in nodes_list | sort(attribute='ip') %}
                        <tr data-ip="{{ node.ip }}">
                            <td data-col="node">
{%   if node.ip == (admin_ip | default('') | string) %}
                                <a href="/ui/d/node-instance?var-id={{ node.ip }}" class="tp-ip tp-admin">{{ node.ip }}<span class="admin-tip">管理节点</span></a>
{%   else %}
                                <a href="/ui/d/node-instance?var-id={{ node.ip }}" class="tp-ip">{{ node.ip }}</a>
{%   endif %}
                            </td>
                            <td data-col="pgsql">
{%   if node.pg_cluster and node.pg_seq %}
                                <a href="/ui/d/pgsql-instance?var-ins={{ node.pg_cluster }}-{{ node.pg_seq }}" class="tp-pill pg" data-cluster="{{ node.pg_cluster }}">{{ node.pg_cluster }}-{{ node.pg_seq }}</a>
{%   else %}
                                <span class="tp-pill empty">-</span>
{%   endif %}
                            </td>
                            <td data-col="infra">
{%   if node.infra_seq %}
                                <a href="/ui/d/infra-overview" class="tp-pill">infra-{{ node.infra_seq }}</a>
{%   else %}
                                <span class="tp-pill empty">-</span>
{%   endif %}
                            </td>
                            <td data-col="etcd">
{%   if node.etcd_seq %}
                                <a href="/ui/d/etcd-overview" class="tp-pill">etcd-{{ node.etcd_seq }}</a>
{%   else %}
                                <span class="tp-pill empty">-</span>
{%   endif %}
                            </td>
                            <td data-col="minio">
{%   if node.minio_cluster and node.minio_seq %}
                                <a href="/ui/d/minio-instance?var-ins={{ node.minio_cluster }}-{{ node.minio_seq }}" class="tp-pill">{{ node.minio_cluster }}-{{ node.minio_seq }}</a>
{%   else %}
                                <span class="tp-pill empty">-</span>
{%   endif %}
                            </td>
                        </tr>
{% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
    </main>

