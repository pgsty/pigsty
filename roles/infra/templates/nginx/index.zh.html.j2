    <script>
        // theme toggle (shares localStorage key with pigsty websites)
        (function () {
            var btn = document.getElementById('themeToggle');
            if (!btn) return;
            btn.addEventListener('click', function () {
                var next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
                document.documentElement.setAttribute('data-theme', next);
                try { localStorage.setItem('pigsty-landing-theme', next); } catch (e) {}
            });
        })();

        // header scroll shadow
        (function () {
            var header = document.getElementById('header');
            window.addEventListener('scroll', function () {
                header.classList.toggle('scrolled', window.pageYOffset > 10);
            }, { passive: true });
        })();

        // reveal service cards on scroll
        (function () {
            var els = document.querySelectorAll('.reveal');
            if (!('IntersectionObserver' in window)) {
                els.forEach(function (el) { el.classList.add('on'); });
                return;
            }
            var io = new IntersectionObserver(function (entries) {
                entries.forEach(function (e) {
                    if (e.isIntersecting) { e.target.classList.add('on'); io.unobserve(e.target); }
                });
            }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });
            els.forEach(function (el) { io.observe(el); });
        })();

        // topology: per-cluster hue (theme-aware colors are computed in CSS)
        (function () {
            var table = document.getElementById('topologyTable');
            if (!table) return;
            document.querySelectorAll('.tp-pill.pg').forEach(function (cell) {
                var str = cell.getAttribute('data-cluster') || '';
                var hash = 0;
                for (var i = 0; i < str.length; i++) {
                    hash = str.charCodeAt(i) + ((hash << 5) - hash);
                    hash = hash & hash;
                }
                var hue = 210 + (Math.abs(hash % 48)) - 24;          /* 186-234: cyan..indigo around PG blue */
                var sat = 40 + (Math.abs(hash >> 8) % 25);           /* 40-65% */
                cell.style.setProperty('--ch', hue);
                cell.style.setProperty('--cs', sat + '%');
            });

            // row / column crosshair highlight
            var thead = table.querySelector('thead');
            var tbody = table.querySelector('tbody');
            function setCol(col, on) {
                var th = thead.querySelector('th[data-col="' + col + '"]');
                if (th) th.classList.toggle('hl', on);
                tbody.querySelectorAll('td[data-col="' + col + '"]').forEach(function (c) {
                    c.classList.toggle('hl', on);
                });
            }
            thead.querySelectorAll('th[data-col]').forEach(function (th) {
                var col = th.getAttribute('data-col');
                th.addEventListener('mouseenter', function () { setCol(col, true); });
                th.addEventListener('mouseleave', function () { setCol(col, false); });
            });
            tbody.querySelectorAll('td[data-col]').forEach(function (cell) {
                var col = cell.getAttribute('data-col');
                cell.addEventListener('mouseenter', function () {
                    setCol(col, true);
                    cell.closest('tr').classList.add('hl');
                });
                cell.addEventListener('mouseleave', function () {
                    setCol(col, false);
                    cell.closest('tr').classList.remove('hl');
                });
            });
        })();

        // section collapse toggles
        (function () {
            document.querySelectorAll('.sec-toggle').forEach(function (btn) {
                var wrap = document.getElementById(btn.getAttribute('data-target'));
                if (!wrap) return;
                btn.addEventListener('click', function () {
                    var collapsed = wrap.classList.toggle('collapsed');
                    btn.classList.toggle('collapsed', collapsed);
                    btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
                });
            });
        })();
    </script>
