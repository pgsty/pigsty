#==============================================================#
# File      :   .env
# Desc      :   InsForge docker configuration entries
# Ctime     :   2026-03-10
# Mtime     :   2026-07-09
# Path      :   app/insforge/.env
# License   :   Apache-2.0 @ https://pigsty.io/docs/about/license/
# Copyright :   2018-2026  Ruohang Feng / Vonng (rh@vonng.com)
#==============================================================#
# https://github.com/InsForge/InsForge

############
# Secrets
# YOU MUST CHANGE THESE BEFORE GOING INTO PRODUCTION
############
JWT_SECRET=your-secret-key-here-must-be-32-char-or-above
ENCRYPTION_KEY=your-encryption-key-here-must-be-32-char-or-above
ROOT_ADMIN_USERNAME=admin@example.com
ROOT_ADMIN_PASSWORD=pigsty
# Legacy aliases kept for older InsForge images.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=pigsty

############
# Database - Pigsty managed PostgreSQL
############
POSTGRES_HOST=10.10.10.10
POSTGRES_PORT=5432
POSTGRES_DB=insforge
POSTGRES_USER=dbuser_insforge
POSTGRES_PASSWORD=DBUser.Insforge

############
# Ports
############
INSFORGE_VERSION=v2.2.6
DENO_RUNTIME_VERSION=latest
# Optional image overrides, useful when ghcr.io is slow or blocked.
#INSFORGE_IMAGE=ghcr.io/insforge/insforge-oss:v2.2.6
#DENO_RUNTIME_IMAGE=ghcr.io/insforge/deno-runtime:latest
POSTGREST_PORT=5430
APP_PORT=7130
DENO_PORT=7133

############
# API URL (leave empty for relative URL, set to public URL if using reverse proxy)
############
API_BASE_URL=
VITE_API_BASE_URL=
MAX_JSON_BODY_SIZE=100mb
MAX_URLENCODED_BODY_SIZE=10mb
TRUST_PROXY=

############
# Cloud API / MCP Access (Optional)
############
# Optional API key for MCP / API access. If empty, InsForge will generate one.
ACCESS_API_KEY=
# Optional anon key for public client requests. If set, it must start with anon_.
ACCESS_ANON_KEY=
# Optional cloud control plane endpoint, only needed for managed / hybrid integrations.
CLOUD_API_HOST=

############
# LLM Model Gateway (Optional)
# Get your API key from https://openrouter.ai/keys
############
OPENROUTER_API_KEY=
MAX_COMPLETION_TOKENS=16384

############
# Object Storage / CDN (Optional)
############
# AWS credentials used for CloudWatch logs and as a fallback for S3 storage.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
# S3-compatible storage credentials (for MinIO, Wasabi, etc.). Falls back to AWS_* if not set.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
# Path-style addressing is required by MinIO and most local S3-compatible stores.
S3_FORCE_PATH_STYLE=true
# Optional config bucket used by deployment/config features.
AWS_CONFIG_BUCKET=
AWS_CONFIG_REGION=
# Optional CloudFront delivery for object storage.
AWS_CLOUDFRONT_URL=
AWS_CLOUDFRONT_KEY_PAIR_ID=
AWS_CLOUDFRONT_PRIVATE_KEY=
# Max upload file size in bytes, default is managed by InsForge if empty.
MAX_FILE_SIZE=

############
# Deno Runtime / Edge Functions
############
WORKER_TIMEOUT_MS=60000
# Deno Deploy for edge functions (optional)
DENO_DEPLOY_TOKEN=
DENO_DEPLOY_ORG_ID=
FUNCTIONS_DOMAIN=
# Legacy aliases kept for older InsForge images.
DENO_SUBHOSTING_TOKEN=
DENO_SUBHOSTING_ORG_ID=

############
# Site Deployment / Compute (Optional)
############
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
FLY_API_TOKEN=
FLY_ORG=
COMPUTE_DOMAIN=

############
# Payments (Optional)
############
STRIPE_TEST_SECRET_KEY=
STRIPE_LIVE_SECRET_KEY=
RAZORPAY_TEST_KEY_ID=
RAZORPAY_TEST_KEY_SECRET=
RAZORPAY_LIVE_KEY_ID=
RAZORPAY_LIVE_KEY_SECRET=

############
# Multi-tenant Cloud Metadata (Optional)
############
DEPLOYMENT_ID=
PROJECT_ID=
APP_KEY=

############
# Logging / Telemetry
############
LOG_LEVEL=info
INSFORGE_TELEMETRY_DISABLED=

############
# OAuth Configuration (Optional)
############
# Google OAuth - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub OAuth - https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Discord OAuth - https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Microsoft OAuth - https://portal.azure.com/
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# LinkedIn OAuth - https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# X/Twitter OAuth - https://developer.twitter.com/en/portal/dashboard
X_CLIENT_ID=
X_CLIENT_SECRET=
# Apple OAuth - https://developer.apple.com/account/resources/identifiers/list
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
