# Hindsight : https://github.com/vectorize-io/hindsight

############
# Image / Ports
############
HINDSIGHT_VERSION=latest
HINDSIGHT_API_HOST=0.0.0.0
HINDSIGHT_API_PORT=8888
HINDSIGHT_API_PUBLISH_PORT=8888
HINDSIGHT_UI_PUBLISH_PORT=9999
HINDSIGHT_MODEL_CACHE=/data/hindsight

############
# PostgreSQL - Pigsty managed
############
HINDSIGHT_DB_HOST=10.10.10.10
HINDSIGHT_DB_PORT=5432
HINDSIGHT_DB_NAME=hindsight
HINDSIGHT_DB_USER=hindsight
HINDSIGHT_DB_PASSWORD=DBUser.Hindsight
HINDSIGHT_DB_SCHEMA=public

HINDSIGHT_API_DATABASE_URL=postgresql://${HINDSIGHT_DB_USER}:${HINDSIGHT_DB_PASSWORD}@${HINDSIGHT_DB_HOST}:${HINDSIGHT_DB_PORT}/${HINDSIGHT_DB_NAME}
HINDSIGHT_API_MIGRATION_DATABASE_URL=${HINDSIGHT_API_DATABASE_URL}
HINDSIGHT_API_DATABASE_SCHEMA=${HINDSIGHT_DB_SCHEMA}
HINDSIGHT_API_VECTOR_EXTENSION=pgvector
HINDSIGHT_API_TEXT_SEARCH_EXTENSION=native

############
# LLM Configuration
############
# Default to `none` so the stack boots without any external model provider.
# Switch to ollama/openai/groq/... to enable fact extraction, consolidation and reflect.
HINDSIGHT_API_LLM_PROVIDER=none
HINDSIGHT_API_LLM_MODEL=gpt-5-mini
HINDSIGHT_API_LLM_API_KEY=
#HINDSIGHT_API_LLM_BASE_URL=https://api.openai.com/v1

# Example: local Ollama running on the same host
# (docker-compose maps host.docker.internal automatically)
#HINDSIGHT_API_LLM_PROVIDER=ollama
#HINDSIGHT_API_LLM_BASE_URL=http://host.docker.internal:11434/v1
#HINDSIGHT_API_LLM_MODEL=qwen3:8b

# Example: OpenAI compatible endpoint
#HINDSIGHT_API_LLM_PROVIDER=openai
#HINDSIGHT_API_LLM_BASE_URL=https://api.openai.com/v1
#HINDSIGHT_API_LLM_API_KEY=sk-xxxxxxxx
#HINDSIGHT_API_LLM_MODEL=gpt-5-mini

############
# Optional Search / Runtime Tuning
############
HINDSIGHT_API_LOG_LEVEL=info

# Better multilingual / Chinese retrieval path:
# 1. install Pigsty extensions: vchord + vchord_bm25
# 2. switch both options below to `vchord`
#HINDSIGHT_API_VECTOR_EXTENSION=vchord
#HINDSIGHT_API_TEXT_SEARCH_EXTENSION=vchord

# Persist downloaded local reranker / embedding models across container restarts
#HINDSIGHT_API_EMBEDDINGS_PROVIDER=local
#HINDSIGHT_API_RERANKER_PROVIDER=local
